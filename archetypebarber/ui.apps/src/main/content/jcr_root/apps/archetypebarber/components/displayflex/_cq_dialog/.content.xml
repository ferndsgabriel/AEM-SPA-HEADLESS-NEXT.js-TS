<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
                xmlns:cq="http://www.day.com/jcr/cq/1.0"
                xmlns:jcr="http://www.jcp.org/jcr/1.0"
                xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
                jcr:primaryType="nt:unstructured"
                jcr:title="Display Flex"
                sling:resourceType="cq/gui/components/authoring/dialog">
        <content
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/container">
                <items jcr:primaryType="nt:unstructured">
                <tabs
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/tabs"
                        maximized="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                        
                        <!-- LAYOUT TAB -->
                        <layout
                                jcr:primaryType="nt:unstructured"
                                jcr:title="Layout"
                                sling:resourceType="granite/ui/components/coral/foundation/container"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                <columns
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                        margin="{Boolean}true">
                                        <items jcr:primaryType="nt:unstructured">
                                        <column
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                                <items jcr:primaryType="nt:unstructured">

                                                <!-- FLEX DIRECTION -->
                                                <flexDirection
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                        fieldLabel="Flex Direction"
                                                        fieldDescription="Choose how child components are arranged."
                                                        name="./flexDirection"
                                                        required="{Boolean}true">
                                                        <items jcr:primaryType="nt:unstructured">
                                                        <column
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Stacked (column)"
                                                                value="column"/>
                                                        <columnReverse
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Stacked reversed (column-reverse)"
                                                                value="column-reverse"/>
                                                        <row
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Side by side (row)"
                                                                value="row"/>
                                                        <rowReverse
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Side by side reversed (row-reverse)"
                                                                value="row-reverse"/>
                                                        </items>
                                                </flexDirection>

                                                <!-- GAP - Numeric Field -->
                                                <gap
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                                        fieldLabel="Gap"
                                                        fieldDescription="Space between children in pixels"
                                                        name="./gap"
                                                        min="{Long}0"
                                                        max="{Long}100"
                                                        step="{Long}4"
                                                        value="{Long}0"/>

                                                <!-- PADDING - Numeric Field -->
                                                <padding
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                                        fieldLabel="Padding"
                                                        fieldDescription="Internal spacing in pixels"
                                                        name="./padding"
                                                        min="{Long}0"
                                                        max="{Long}100"
                                                        step="{Long}4"
                                                        value="{Long}0"/>

                                                <!-- ALIGN ITEMS -->
                                                <alignItems
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                        fieldLabel="Align Items"
                                                        fieldDescription="Controls alignment along the cross axis"
                                                        name="./alignItems">
                                                        <items jcr:primaryType="nt:unstructured">
                                                        <flexStart
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Flex Start"
                                                                value="flex-start"/>
                                                        <flexEnd
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Flex End"
                                                                value="flex-end"/>
                                                        <center
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Center"
                                                                value="center"/>
                                                        <stretch
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Stretch"
                                                                value="stretch"/>
                                                        <baseline
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Baseline"
                                                                value="baseline"/>
                                                        </items>
                                                </alignItems>

                                                <!-- JUSTIFY CONTENT -->
                                                <justifyContent
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                        fieldLabel="Justify Content"
                                                        fieldDescription="Controls alignment along the main axis"
                                                        name="./justifyContent">
                                                        <items jcr:primaryType="nt:unstructured">
                                                        <flexStart
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Flex Start"
                                                                value="flex-start"/>
                                                        <flexEnd
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Flex End"
                                                                value="flex-end"/>
                                                        <center
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Center"
                                                                value="center"/>
                                                        <spaceBetween
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Space Between"
                                                                value="space-between"/>
                                                        <spaceAround
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Space Around"
                                                                value="space-around"/>
                                                        <spaceEvenly
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Space Evenly"
                                                                value="space-evenly"/>
                                                        </items>
                                                </justifyContent>

                                                </items>
                                        </column>
                                        </items>
                                </columns>
                                </items>
                        </layout>

                        <!-- STYLES TAB -->
                        <styles
                                jcr:primaryType="nt:unstructured"
                                jcr:title="Styles"
                                sling:resourceType="granite/ui/components/coral/foundation/container"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                <columns
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                        margin="{Boolean}true">
                                        <items jcr:primaryType="nt:unstructured">
                                        <column
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                                <items jcr:primaryType="nt:unstructured">
                                                
                                                <!-- BACKGROUND COLOR -->
                                                <backgroundColor
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/colorfield"
                                                        fieldLabel="Background Color"
                                                        fieldDescription="Select background color"
                                                        name="./backgroundColor"
                                                        emptyText="transparent"
                                                        showProperties="{Boolean}true"
                                                        showDefaultColors="{Boolean}true"
                                                        showSwatches="{Boolean}true"/>

                                                </items>
                                        </column>
                                        </items>
                                </columns>
                                </items>
                        </styles>

                        </items>
                </tabs>
                </items>
        </content>
</jcr:root>